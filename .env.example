# ─────────────────────────────────────────────
# Environment Variables Template
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Option A: Single DATABASE_URL (used automatically on Render / any PaaS)
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/finance_tracker

# Option B: Individual MySQL vars (local development)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Your root pass word
MYSQL_DATABASE=finance_tracker

# ── Flask ─────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=random long string
FLASK_ENV=development
FLASK_DEBUG=True

# ── Cache ─────────────────────────────────────
# Seconds before cached analytics expire
CACHE_TIMEOUT=300

# ── Rate Limiting ─────────────────────────────
RATELIMIT_DEFAULT=100 per minute
